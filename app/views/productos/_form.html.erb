<%= form_with model: @producto, class: "bg-white rounded-xl border border-[#E8E0D4] shadow-sm p-8" do |f| %>
  <% if @producto.errors.any? %>
    <div class="bg-[#F4DCDC] border border-[#A63D2F]/30 rounded-lg p-4 mb-8">
      <h3 class="text-[#A63D2F] font-semibold mb-2">Se encontraron <%= pluralize(@producto.errors.count, "error") %>:</h3>
      <ul class="list-disc list-inside text-[#A63D2F]/80 text-sm">
        <% @producto.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Información básica -->
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-[#2C1810] mb-4" style="font-family: 'Playfair Display', serif;">Información básica</h2>
    <div class="space-y-5">
      <div>
        <%= f.label :nombre, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.text_field :nombre, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
      <div>
        <%= f.label :descripcion, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.text_area :descripcion, rows: 4, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
    </div>
  </div>

  <div class="border-t border-[#E8E0D4] my-6"></div>

  <!-- Precios -->
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-[#2C1810] mb-4" style="font-family: 'Playfair Display', serif;">Precios</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :precio_compra, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.number_field :precio_compra, step: 0.01, min: 0, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
      <div>
        <%= f.label :precio_venta, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.number_field :precio_venta, step: 0.01, min: 0, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
    </div>
  </div>

  <div class="border-t border-[#E8E0D4] my-6"></div>

  <!-- Detalles -->
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-[#2C1810] mb-4" style="font-family: 'Playfair Display', serif;">Detalles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :estado, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.select :estado, Producto.estados.keys.map { |e| [e.humanize, e] }, { prompt: "Seleccionar estado" }, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
      <div>
        <%= f.label :categoria, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.select :categoria, ["Muebles", "Decoración", "Arte", "Vajilla", "Iluminación", "Textil", "Joyería", "Herramientas", "Libros", "Otros"], { prompt: "Seleccionar categoría" }, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
      <div>
        <%= f.label :anio_aprox, "Año aproximado", class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.number_field :anio_aprox, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
      <div>
        <%= f.label :uso, class: "block text-sm font-medium text-[#6B5744] mb-1.5" %>
        <%= f.text_field :uso, class: "w-full rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      </div>
    </div>
  </div>

  <div class="border-t border-[#E8E0D4] my-6"></div>

  <!-- Fotografías -->
  <div class="mb-8" data-controller="photo-preview camera">
    <h2 class="text-lg font-semibold text-[#2C1810] mb-4" style="font-family: 'Playfair Display', serif;">Fotografías</h2>

    <div class="flex flex-wrap gap-3 mb-3">
      <button type="button" data-action="camera#open"
        class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold text-white cursor-pointer transition-all duration-200"
        style="background-color: var(--accent);"
        onmouseover="this.style.backgroundColor='#9A7209'" onmouseout="this.style.backgroundColor='#B8860B'">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Tomar foto
      </button>

      <label class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold cursor-pointer transition-all duration-200 border border-[#E8E0D4] text-[#6B5744] hover:bg-[#F5ECD7]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Subir desde galería
        <%= f.file_field :fotos, multiple: true, accept: "image/*", data: { action: "change->photo-preview#preview", camera_target: "fileInput" }, class: "hidden" %>
      </label>
    </div>

    <div data-photo-preview-target="preview" data-camera-target="preview" class="mt-3 flex flex-wrap gap-2"></div>

    <% if @producto.fotos.attached? %>
      <div class="mt-3 flex flex-wrap gap-2">
        <% @producto.fotos.each do |foto| %>
          <%= image_tag foto.variant(resize_to_limit: [100, 100]), class: "rounded-lg border border-[#E8E0D4]" %>
        <% end %>
      </div>
    <% end %>

    <!-- Modal cámara -->
    <div data-camera-target="modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center" style="background: rgba(28, 18, 16, 0.9);">
      <div class="relative w-full max-w-lg mx-4">
        <video data-camera-target="video" autoplay playsinline class="w-full rounded-xl shadow-2xl"></video>
        <canvas data-camera-target="canvas" class="hidden"></canvas>
        <div class="absolute bottom-6 left-0 right-0 flex items-center justify-center gap-6">
          <button type="button" data-action="camera#capture"
            class="w-16 h-16 rounded-full border-4 border-white shadow-lg cursor-pointer transition-transform hover:scale-110"
            style="background-color: var(--accent);">
          </button>
          <button type="button" data-action="camera#close"
            class="w-10 h-10 rounded-full bg-white/20 backdrop-blur text-white flex items-center justify-center cursor-pointer hover:bg-white/30 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div>
    <%= f.submit class: "w-full rounded-lg bg-[#B8860B] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#9A7209] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#B8860B] cursor-pointer transition-all duration-200" %>
  </div>
<% end %>
