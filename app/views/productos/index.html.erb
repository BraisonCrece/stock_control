<div class="w-full">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-10">
    <h1 class="text-3xl font-bold text-[#2C1810]" style="font-family: 'Playfair Display', serif;">Inventario</h1>
    <%= link_to new_producto_path, class: "inline-flex items-center gap-2 rounded-lg bg-[#B8860B] px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[#9A7209] transition-all duration-200" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
      Nuevo Producto
    <% end %>
  </div>

  <%= form_with url: productos_path, method: :get, data: { controller: "search", turbo_frame: "productos" }, class: "mb-8 flex flex-col gap-4" do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :q, value: params[:q], placeholder: "Buscar en el inventario...", data: { action: "input->search#search" }, class: "flex-1 rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] placeholder-[#9C8B7A] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 transition-all duration-200" %>
      <%= f.submit "Buscar", class: "inline-flex items-center rounded-lg bg-[#6B5744] px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[#2C1810] cursor-pointer transition-all duration-200" %>
    </div>
    <div class="flex gap-4">
      <%= f.select :categoria, options_for_select(Producto.distinct.where.not(categoria: [nil, ""]).pluck(:categoria).sort, params[:categoria]), { include_blank: "Todas las categorías" }, data: { action: "change->search#search" }, class: "rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 text-sm transition-all duration-200" %>
      <%= f.select :estado, options_for_select(Producto.estados.keys.map { |e| [e.humanize, e] }, params[:estado]), { include_blank: "Todos los estados" }, data: { action: "change->search#search" }, class: "rounded-lg border border-[#E8E0D4] bg-white text-[#2C1810] shadow-sm focus:border-[#B8860B] focus:ring-[#B8860B] focus:ring-1 text-sm transition-all duration-200" %>
    </div>
  <% end %>

  <%= turbo_frame_tag "productos" do %>
    <% if @productos.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @productos.each do |producto| %>
          <%= link_to producto, class: "group block bg-white rounded-xl border border-[#E8E0D4] shadow-sm hover:shadow-lg hover:-translate-y-0.5 hover:border-b-[#B8860B] hover:border-b-2 transition-all duration-200 overflow-hidden" do %>
            <div class="aspect-square bg-[#FAF7F2] flex items-center justify-center overflow-hidden rounded-t-xl">
              <% if producto.fotos.attached? %>
                <%= image_tag producto.fotos.first.variant(resize_to_limit: [300, 300]), class: "object-cover w-full h-full group-hover:scale-105 transition-transform duration-300" %>
              <% else %>
                <div class="flex flex-col items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#E8E0D4]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <span class="text-[#9C8B7A] text-xs">Sin fotografía</span>
                </div>
              <% end %>
            </div>
            <div class="p-4">
              <h2 class="font-semibold text-[#2C1810] truncate"><%= producto.nombre %></h2>
              <p class="text-lg font-bold text-[#B8860B] mt-1"><%= formato_precio(producto.precio_venta) %></p>
              <div class="flex items-center justify-between mt-3">
                <span class="text-xs text-[#9C8B7A]"><%= producto.categoria %></span>
                <%
                  badge_colors = {
                    "nuevo" => "bg-[#E8F0E8] text-[#3D5E3D]",
                    "bueno" => "bg-[#E4ECF4] text-[#3D5470]",
                    "aceptable" => "bg-[#F5ECD7] text-[#8B6914]",
                    "desgastado" => "bg-[#F4E4DC] text-[#8B4F3A]",
                    "reparacion" => "bg-[#F4DCDC] text-[#7F3333]"
                  }
                %>
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium <%= badge_colors[producto.estado] %>">
                  <%= producto.estado.humanize %>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-[#E8E0D4] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        <p class="text-[#9C8B7A] text-lg" style="font-family: 'Playfair Display', serif;">No se encontraron piezas en el inventario.</p>
        <p class="text-[#9C8B7A] text-sm mt-1">Intenta ajustar los filtros o agrega un nuevo producto.</p>
      </div>
    <% end %>
  <% end %>
</div>
