<div class="w-full max-w-4xl mx-auto">
  <div class="mb-8">
    <%= link_to productos_path, class: "inline-flex items-center gap-1 text-[#B8860B] hover:text-[#9A7209] text-sm font-medium transition-all duration-200" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
      Volver al inventario
    <% end %>
  </div>

  <% if @producto.fotos.attached? %>
    <div class="mb-8">
      <% fotos = @producto.fotos.to_a %>
      <% if fotos.size == 1 %>
        <div class="rounded-xl overflow-hidden shadow-md">
          <%= image_tag fotos.first.variant(resize_to_limit: [800, 600]), class: "w-full object-cover hover:scale-[1.02] transition-transform duration-300" %>
        </div>
      <% else %>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          <% fotos.each_with_index do |foto, i| %>
            <div class="<%= i == 0 ? 'col-span-2 row-span-2' : '' %> rounded-xl overflow-hidden shadow-md">
              <%= image_tag foto.variant(resize_to_limit: [i == 0 ? 800 : 400, i == 0 ? 600 : 400]), class: "w-full h-full object-cover hover:scale-[1.02] transition-transform duration-300" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-[#E8E0D4] shadow-sm p-8">
    <!-- Header -->
    <div class="flex justify-between items-start mb-6">
      <h1 class="text-3xl font-bold text-[#2C1810]" style="font-family: 'Playfair Display', serif;"><%= @producto.nombre %></h1>
      <%
        badge_colors = {
          "nuevo" => "bg-[#E8F0E8] text-[#3D5E3D]",
          "bueno" => "bg-[#E4ECF4] text-[#3D5470]",
          "aceptable" => "bg-[#F5ECD7] text-[#8B6914]",
          "desgastado" => "bg-[#F4E4DC] text-[#8B4F3A]",
          "reparacion" => "bg-[#F4DCDC] text-[#7F3333]"
        }
      %>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium <%= badge_colors[@producto.estado] %>">
        <%= @producto.estado.humanize %>
      </span>
    </div>

    <!-- Description -->
    <% if @producto.descripcion.present? %>
      <p class="text-[#6B5744] leading-relaxed mb-6 whitespace-pre-wrap"><%= @producto.descripcion %></p>
    <% end %>

    <div class="border-t border-[#E8E0D4] my-6"></div>

    <!-- Pricing -->
    <div class="grid grid-cols-2 gap-6 mb-6">
      <div>
        <span class="text-xs uppercase tracking-wider text-[#9C8B7A]">Precio compra</span>
        <p class="text-lg font-semibold text-[#2C1810] mt-1"><%= formato_precio(@producto.precio_compra) %></p>
      </div>
      <div>
        <span class="text-xs uppercase tracking-wider text-[#9C8B7A]">Precio venta</span>
        <p class="text-lg font-semibold text-[#B8860B] mt-1"><%= formato_precio(@producto.precio_venta) %></p>
      </div>
    </div>

    <% if @producto.precio_venta.present? && @producto.precio_compra.present? && @producto.precio_compra > 0 && @producto.precio_venta > @producto.precio_compra %>
      <% margin = ((@producto.precio_venta - @producto.precio_compra).to_f / @producto.precio_compra * 100).round(1) %>
      <div class="inline-flex items-center gap-1.5 bg-[#E8F0E8] text-[#5B7F5E] rounded-full px-3 py-1 text-sm font-medium mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"/></svg>
        Margen: +<%= margin %>%
      </div>
    <% end %>

    <div class="border-t border-[#E8E0D4] my-6"></div>

    <!-- Details -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 text-sm">
      <div>
        <span class="text-xs uppercase tracking-wider text-[#9C8B7A]">Categoría</span>
        <p class="font-semibold text-[#2C1810] mt-1"><%= @producto.categoria %></p>
      </div>
      <% if @producto.anio_aprox.present? %>
        <div>
          <span class="text-xs uppercase tracking-wider text-[#9C8B7A]">Año aproximado</span>
          <p class="font-semibold text-[#2C1810] mt-1"><%= @producto.anio_aprox %></p>
        </div>
      <% end %>
      <% if @producto.uso.present? %>
        <div>
          <span class="text-xs uppercase tracking-wider text-[#9C8B7A]">Uso</span>
          <p class="font-semibold text-[#2C1810] mt-1"><%= @producto.uso %></p>
        </div>
      <% end %>
      <div>
        <span class="text-xs uppercase tracking-wider text-[#9C8B7A]">Publicado por</span>
        <p class="font-semibold text-[#2C1810] mt-1"><%= @producto.user.nombre %></p>
      </div>
    </div>

    <% if current_user&.admin? || @producto.user_id == current_user&.id %>
      <div class="border-t border-[#E8E0D4] my-6"></div>

      <div class="flex gap-3">
        <%= link_to edit_producto_path(@producto), class: "inline-flex items-center gap-2 rounded-lg bg-[#B8860B] px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[#9A7209] transition-all duration-200" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
          Editar
        <% end %>
        <%= button_to @producto, method: :delete, data: { turbo_confirm: "¿Estás seguro de que deseas eliminar este producto?" }, class: "inline-flex items-center gap-2 rounded-lg border border-[#A63D2F] px-5 py-2.5 text-sm font-semibold text-[#A63D2F] hover:bg-[#A63D2F] hover:text-white transition-all duration-200" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          Eliminar
        <% end %>
      </div>
    <% end %>
  </div>
</div>
