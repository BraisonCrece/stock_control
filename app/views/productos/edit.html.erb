<div class="w-full max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to producto_path(@producto), class: "inline-flex items-center gap-1 text-[#B8860B] hover:text-[#9A7209] text-sm font-medium transition-all duration-200" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
      Volver al producto
    <% end %>
  </div>
  <h1 class="text-3xl font-bold text-[#2C1810] mb-8" style="font-family: 'Playfair Display', serif;">Editar Producto</h1>
  <%= render "form" %>
</div>
