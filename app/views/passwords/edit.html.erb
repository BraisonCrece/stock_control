<div class="flex min-h-[60vh] items-center justify-center">
  <div class="w-full max-w-md bg-white rounded-lg shadow-md p-8">
    <h1 class="font-bold text-2xl text-gray-900 mb-6 text-center">Actualizar contrasena</h1>

    <% if alert = flash[:alert] %>
      <div class="bg-red-50 border border-red-300 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= alert %></div>
    <% end %>

    <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :password, "Nueva contrasena", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Nueva contrasena", maxlength: 72, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar contrasena", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repite la contrasena", maxlength: 72, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.submit "Guardar", class: "w-full rounded-md px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm cursor-pointer transition" %>
      </div>
    <% end %>
  </div>
</div>
