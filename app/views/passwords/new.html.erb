<div class="flex min-h-[60vh] items-center justify-center">
  <div class="w-full max-w-md bg-white rounded-lg shadow-md p-8">
    <h1 class="font-bold text-2xl text-gray-900 mb-6 text-center">Recuperar contrasena</h1>

    <% if alert = flash[:alert] %>
      <div class="bg-red-50 border border-red-300 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= alert %></div>
    <% end %>

    <%= form_with url: passwords_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Correo electronico", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "tu@correo.com", value: params[:email_address], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.submit "Enviar instrucciones", class: "w-full rounded-md px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm cursor-pointer transition" %>
      </div>

      <div class="text-center text-sm text-gray-500">
        <%= link_to "Volver a iniciar sesion", new_session_path, class: "text-indigo-600 hover:text-indigo-500" %>
      </div>
    <% end %>
  </div>
</div>
