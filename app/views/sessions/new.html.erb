<div class="flex min-h-[60vh] items-center justify-center">
  <div class="w-full max-w-md p-8 rounded-xl card-hover" style="background-color: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(44, 24, 16, 0.06);">
    <h1 class="text-2xl font-bold text-center mb-1" style="font-family: 'Playfair Display', serif; color: var(--text-primary);">StockControl</h1>
    <p class="text-center text-sm mb-6" style="color: var(--text-muted);">Accede a tu inventario</p>

    <div class="separator-diamond mb-6"><span>&#9670;</span></div>

    <% if alert = flash[:alert] %>
      <div class="px-4 py-3 rounded-lg text-sm mb-4" style="background-color: #F4DCDC; border: 1px solid #E0B8B8; color: #7F3333;"><%= alert %></div>
    <% end %>

    <% if notice = flash[:notice] %>
      <div class="px-4 py-3 rounded-lg text-sm mb-4" style="background-color: #E8F0E8; border: 1px solid #C4D9C4; color: #3D5E3D;"><%= notice %></div>
    <% end %>

    <%= form_with url: session_url, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Correo electronico", class: "block text-sm font-medium mb-1", style: "color: var(--text-secondary);" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "tu@correo.com", value: params[:email_address] %>
      </div>

      <div>
        <%= form.label :password, "Contrasena", class: "block text-sm font-medium mb-1", style: "color: var(--text-secondary);" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Tu contrasena", maxlength: 72 %>
      </div>

      <div>
        <%= form.submit "Iniciar sesion", class: "w-full rounded-lg px-4 py-2.5 text-sm font-semibold cursor-pointer transition-colors", style: "background-color: var(--accent); color: #FAF7F2;", onmouseover: "this.style.backgroundColor='#9A7209'", onmouseout: "this.style.backgroundColor='#B8860B'" %>
      </div>

      <div class="separator-diamond mt-6 mb-2"><span>&#9670;</span></div>

      <div class="text-center text-sm space-x-2" style="color: var(--text-muted);">
        <%= link_to "Olvidaste tu contrasena?", new_password_path, class: "font-medium transition-colors", style: "color: var(--accent);", onmouseover: "this.style.color='#9A7209'", onmouseout: "this.style.color='#B8860B'" %>
        <span>&middot;</span>
        <%= link_to "Crear cuenta", new_registration_path, class: "font-medium transition-colors", style: "color: var(--accent);", onmouseover: "this.style.color='#9A7209'", onmouseout: "this.style.color='#B8860B'" %>
      </div>
    <% end %>
  </div>
</div>
